# Backend environment variables
# Copy this file to backend/.env and fill in your real values.
# NEVER commit backend/.env to version control.
# Set these values in your Render dashboard under "Environment Variables".

# ── MongoDB ────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/happy_helper

# ── Server ─────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── JWT — use a long random string (e.g. openssl rand -base64 48) ──
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET_STRING

# ── Admin bypass password (set once, keep secret) ──────────────
ADMIN_PASSWORD=REPLACE_WITH_YOUR_ADMIN_PASSWORD

# ── Cloudinary (image upload) ──────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Email notifications (Gmail App Password) ───────────────────
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password_here
